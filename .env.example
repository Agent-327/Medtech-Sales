# Azure OpenAI / Foundry settings for agent_app.py
AZURE_OPENAI_ENDPOINT=https://your-foundry-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_MODEL=gpt-4.1-1
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional alias names supported by agent_app.py
# FOUNDRY_ENDPOINT=https://your-foundry-resource.openai.azure.com
# FOUNDRY_API_KEY=your_azure_openai_api_key
# FOUNDRY_MODEL=gpt-4.1-1
# FOUNDRY_API_VERSION=2025-04-01-preview

# app.py voice realtime
AZURE_VOICE_API_KEY=your_voice_api_key

# app.py translator
AZURE_TRANSLATOR_KEY=your_translator_api_key

# app.py speech synthesis
AZURE_SPEECH_ENDPOINT=https://your-speech-resource.cognitiveservices.azure.com/
AZURE_SPEECH_KEY=your_speech_api_key
